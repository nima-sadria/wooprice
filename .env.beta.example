# WooPrice Beta — Environment template
# Copy to .env.beta and fill in real values before deploying.
# .env.beta is gitignored. Never commit the file with real secrets.
#
# Generate secrets:
#   python3 -c "import secrets; print(secrets.token_hex(48))"  # 96-char hex

# ── Profile ───────────────────────────────────────────────────────────────────
BETA_ENV=beta
BETA_DOMAIN=your-beta-domain.example.com
BETA_PORT=8085
BETA_SSL_MODE=manual

# ── Database ──────────────────────────────────────────────────────────────────
BETA_DATABASE_URL=postgresql://wooprice_beta:CHANGE_ME_DB_PASSWORD@postgres:5432/wooprice_beta
BETA_POSTGRES_DB=wooprice_beta
BETA_POSTGRES_USER=wooprice_beta
BETA_POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── JWT and API secrets ───────────────────────────────────────────────────────
# Must be at least 64 characters for JWT_SECRET, 32 for REST_API_SECRET
BETA_JWT_SECRET=CHANGE_ME_64_CHAR_MIN_eg_run_python_secrets_token_hex_48_here_xxxx
BETA_REST_API_SECRET=CHANGE_ME_32_CHAR_MIN_eg_run_python_secrets_here

# ── Nextcloud source ──────────────────────────────────────────────────────────
BETA_NEXTCLOUD_URL=https://your-nextcloud.example.com
BETA_NEXTCLOUD_FILE_PATH=/remote.php/dav/files/username/folder/price-list.xlsx
BETA_NEXTCLOUD_USERNAME=your_nextcloud_user
BETA_NEXTCLOUD_PASSWORD=CHANGE_ME_NEXTCLOUD_PASSWORD

# ── WooCommerce channel ───────────────────────────────────────────────────────
BETA_WOOCOMMERCE_URL=https://your-woocommerce.example.com
BETA_WOOCOMMERCE_KEY=ck_CHANGE_ME_WOOCOMMERCE_KEY
BETA_WOOCOMMERCE_SECRET=cs_CHANGE_ME_WOOCOMMERCE_SECRET

# ── Locale ────────────────────────────────────────────────────────────────────
BETA_TIMEZONE=Asia/Tehran
BETA_CURRENCY=IRR

# ── Admin ─────────────────────────────────────────────────────────────────────
BETA_ADMIN_EMAIL=admin@example.com

# ── Storage paths (resolved inside the container) ─────────────────────────────
BETA_STORAGE_PATH=/data/storage
BETA_BACKUP_PATH=/data/backups

# ── Optional — defaults shown ─────────────────────────────────────────────────
BETA_LOG_LEVEL=INFO
BETA_MAX_UPLOAD_MB=50
BETA_WORKER_CONCURRENCY=2
BETA_SCHEDULER_POLL_SECONDS=30
BETA_BACKUP_RETAIN_DAYS=30
BETA_JWT_ACCESS_TTL_MINUTES=15
BETA_JWT_REFRESH_TTL_DAYS=7
