# ── Nextcloud WebDAV ─────────────────────────────────────────────────────────
NEXTCLOUD_URL=https://your-nextcloud-domain.com
NEXTCLOUD_USER=your_nextcloud_username
NEXTCLOUD_PASSWORD=your_nextcloud_password
# Format: /remote.php/dav/files/{username}/{folder}/{filename}.xlsx
NEXTCLOUD_FILE_PATH=/remote.php/dav/files/your_nextcloud_username/folder/price-list.xlsx

# ── WooCommerce REST API ──────────────────────────────────────────────────────
WC_URL=https://your-woocommerce-site.com
WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
# SQLite (default) — for Docker use sqlite:////app/data/wooprice.db
DATABASE_URL=sqlite:///./wooprice.db

# ── Security ─────────────────────────────────────────────────────────────────
# JWT secret — REQUIRED in production. Must be at least 32 bytes (64+ recommended).
# Generate with: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=change-me-in-production

# ── Access Control (Phase 0) ─────────────────────────────────────────────────
# Super admins bypass the app_users DB table entirely.
# These users can ALWAYS log in even if app_users is empty.
# Comma-separated Nextcloud usernames.
SUPER_ADMIN_USERS=woo,admin

# Bootstrap seed: users created in app_users on first startup if not already present.
# Supports 'username' or 'username:email' format (comma-separated).
# Email is stored in app_users.email and enables login via email address.
# Never overwrites existing rows. Backfills email if previously unset. Safe to leave set permanently.
BOOTSTRAP_APP_ADMINS=woo:woo@softpple.com,admin:nima.sadria@gmail.com
BOOTSTRAP_APP_USERS=az1328:amiraliqaz1328b@gmail.com,farshadkh:farshadkhodadad2@gmail.com,nima.sadria:nima.sadria@yahoo.com,soheil:soheilzarei82@gmail.com

# ── Cache / Sync ─────────────────────────────────────────────────────────────
# Product cache TTL in hours (0 = disable caching)
WC_CACHE_TTL_HOURS=6
# Auto-fetch interval in hours (0 = disable auto-fetch)
WC_AUTO_FETCH_HOURS=4
